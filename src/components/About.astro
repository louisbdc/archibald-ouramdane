<section class="sec about" id="apropos">
  <div class="wrap about-grid">
    <div class="about-portrait reveal">
      <img
        src="https://archibald-ouramdane.fr/wp-content/uploads/2025/11/Archibald-Ouramdane-Therapeute-des-fascias-sur-Marseille-2-scaled.jpg"
